---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="About | The Rogues" description="Meet The Rogues — Shropshire's go-to rock covers band. Learn about the band, our sound, and what drives us.">
  <section class="page-header">
    <div class="container">
      <h1 class="section-title">About <span class="accent">The Rogues</span></h1>
      <p class="section-subtitle" style="margin: 0 auto;">Shropshire-born, rock-fuelled, and always up for a gig.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2 class="section-title" style="font-size: 1.8rem;">The <span class="accent">Story</span></h2>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.8;">
            We're The Rogues — a rock covers band based in Shropshire, right in the heart of the Welsh Marches.
            We play the songs everyone knows and loves, from classic rock anthems to modern bangers, and we play
            them loud (or quiet, if you ask nicely).
          </p>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.8;">
            Whether it's a packed pub on a Saturday night, a wedding reception that needs to go up a gear, or a
            private party that deserves a proper soundtrack — we bring the energy. Every song gets the full
            treatment, and yes, there will be guitar solos.
          </p>
          <p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.8;">
            We also offer acoustic duo and trio options for venues and events where a full band might be too much
            — but we still bring the same passion and quality. Think singalong classics, stripped-back rock, and
            the kind of atmosphere that keeps people coming back.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Band members placeholder -->
  <section class="section" style="background: #141414;">
    <div class="container">
      <h2 class="section-title">Meet The <span class="accent">Band</span></h2>
      <p class="section-subtitle">The faces behind the noise.</p>
      <div class="card-grid">
        <div class="card" style="text-align: center;">
          <div style="width: 150px; height: 150px; border-radius: 50%; background: var(--bg-dark); margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; border: 2px solid var(--border);">
            <span style="color: var(--text-muted); font-size: 0.8rem;">Photo</span>
          </div>
          <h3>Member Name</h3>
          <p style="color: var(--accent-light); font-size: 0.9rem; margin-bottom: 0.5rem;">Vocals / Guitar</p>
          <p>Bio coming soon.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="width: 150px; height: 150px; border-radius: 50%; background: var(--bg-dark); margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; border: 2px solid var(--border);">
            <span style="color: var(--text-muted); font-size: 0.8rem;">Photo</span>
          </div>
          <h3>Member Name</h3>
          <p style="color: var(--accent-light); font-size: 0.9rem; margin-bottom: 0.5rem;">Lead Guitar</p>
          <p>Bio coming soon.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="width: 150px; height: 150px; border-radius: 50%; background: var(--bg-dark); margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; border: 2px solid var(--border);">
            <span style="color: var(--text-muted); font-size: 0.8rem;">Photo</span>
          </div>
          <h3>Member Name</h3>
          <p style="color: var(--accent-light); font-size: 0.9rem; margin-bottom: 0.5rem;">Bass</p>
          <p>Bio coming soon.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="width: 150px; height: 150px; border-radius: 50%; background: var(--bg-dark); margin: 0 auto 1.5rem; display: flex; align-items: center; justify-content: center; border: 2px solid var(--border);">
            <span style="color: var(--text-muted); font-size: 0.8rem;">Photo</span>
          </div>
          <h3>Member Name</h3>
          <p style="color: var(--accent-light); font-size: 0.9rem; margin-bottom: 0.5rem;">Drums</p>
          <p>Bio coming soon.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">Want Us At <span class="accent">Your Event</span>?</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">Get in touch and let's make it happen.</p>
      <a href="/enquire" class="btn btn-primary">Enquire Now</a>
    </div>
  </section>
</Base>
