---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="Gallery | The Rogues" description="Photos and videos of The Rogues performing live across Shropshire and beyond.">
  <section class="page-header">
    <div class="container">
      <h1 class="section-title"><span class="accent">Gallery</span></h1>
      <p class="section-subtitle" style="margin: 0 auto;">See us in action.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title" style="font-size: 1.6rem;">Live <span class="accent">Photos</span></h2>
      <p class="section-subtitle">Pics from gigs across Shropshire and beyond.</p>
      <div class="gallery-grid">
        <!-- Replace these placeholders with actual images from Facebook -->
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
        <div class="gallery-item gallery-placeholder">
          <span>Photo coming soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Videos section - future -->
  <section class="section" style="background: #141414;">
    <div class="container">
      <h2 class="section-title" style="font-size: 1.6rem;"><span class="accent">Videos</span></h2>
      <p class="section-subtitle">Live performances and highlights — coming soon.</p>
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
        <div class="card" style="text-align: center; padding: 3rem;">
          <p style="color: var(--text-muted);">Video content coming soon. In the meantime, check us out on <a href="https://www.facebook.com/ludlowrogues/" target="_blank" rel="noopener noreferrer">Facebook</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">Want Us At <span class="accent">Your Event</span>?</h2>
      <p class="section-subtitle" style="margin: 0 auto 2rem;">We'd love to play for you.</p>
      <a href="/enquire" class="btn btn-primary">Enquire Now</a>
    </div>
  </section>
</Base>
