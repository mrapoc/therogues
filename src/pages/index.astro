---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="The Rogues | Shropshire Rock Covers Band">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">The <span class="accent">Rogues</span></h1>
      <p class="hero-tagline">Upbeat classic & modern rock covers for every occasion</p>
      <p class="hero-location">Shropshire, UK</p>
      <div class="hero-buttons">
        <a href="/enquire" class="btn btn-primary">Book Us</a>
        <a href="/setlist" class="btn btn-outline">View Set List</a>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What We <span class="accent">Do</span></h2>
      <p class="section-subtitle">Three ways to rock your event — from chilled acoustics to full-volume face-melters.</p>
      <div class="card-grid">
        <div class="card">
          <div class="card-icon">🎸</div>
          <h3>Full Band</h3>
          <p>The complete Rogues experience. Cranked amps, face-melting solos, and a setlist that'll have everyone on their feet. Perfect for weddings, parties, and festivals.</p>
        </div>
        <div class="card">
          <div class="card-icon">🎵</div>
          <h3>Acoustic Duo</h3>
          <p>Stripped-back but never quiet. Ideal for pubs, restaurants, and intimate gatherings. All the energy, dialled to suit your venue.</p>
        </div>
        <div class="card">
          <div class="card-icon">🎶</div>
          <h3>Acoustic Trio</h3>
          <p>The best of both worlds. Fuller sound than a duo with the flexibility to suit mid-size venues, weddings, and private parties.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY BOOK US -->
  <section class="section" style="background: #141414;">
    <div class="container">
      <h2 class="section-title">Why Book <span class="accent">The Rogues</span>?</h2>
      <div class="card-grid">
        <div class="card">
          <h3>Your Setlist, Your Way</h3>
          <p>Browse our full repertoire and pick the songs you want to hear. We'll build the perfect setlist for your event.</p>
        </div>
        <div class="card">
          <h3>Flexible Lineups</h3>
          <p>From an intimate acoustic duo to a full rock band — we scale to fit your venue and budget.</p>
        </div>
        <div class="card">
          <h3>Shropshire Based</h3>
          <p>Local to the Welsh Marches and happy to travel. We know the venues, we know the crowds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">Ready to <span class="accent">Rock</span>?</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">Tell us about your event, pick your songs, and we'll sort the rest.</p>
      <a href="/enquire" class="btn btn-primary">Get a Quote</a>
    </div>
  </section>
</Base>
